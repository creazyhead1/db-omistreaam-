-- 1. Tabela: Usuario (Listagem simples)
SELECT * FROM `Usuario`;

-- 2. Tabela: Canal (Busca o canal associando os dados do dono via JOIN)
SELECT u.nickname, c.nome_canal, c.descricao 
FROM `Usuario` u
JOIN `Canal` c ON u.id_usuario = c.id_usuario;

-- 3. Tabela: Live (Filtrando transmissões que estão ativas)
SELECT titulo_live, status FROM `Live` WHERE status = 'Iniciada';

-- 4. Tabela: Categoria (Listagem de tags existentes)
SELECT * FROM `Categoria`;

-- 5. Tabela: Live_Categoria (Verifica quais títulos pertencem a uma categoria específica)
SELECT l.titulo_live, cat.titulo 
FROM `Live` l
JOIN `Live_Categoria` lc ON l.id_live = lc.id_live
JOIN `Categoria` cat ON lc.id_categoria = cat.id_categoria
WHERE cat.titulo = 'Software Development';

-- 6. Tabela: Inscricao (Agrupamento e contagem de inscritos por canal)
SELECT id_canal, COUNT(id_usuario) AS total_inscritos 
FROM `Inscricao` 
WHERE id_canal = 10;

-- 7. Tabela: Chat_mensagem (Filtra mensagens de uma live com o nickname do remetente)
SELECT m.data_mensagem, u.nickname, m.conteudo 
FROM `Chat_mensagem` m
JOIN `Usuario` u ON m.id_usuario = u.id_usuario
WHERE m.id_live = 100;

